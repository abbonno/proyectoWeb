---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';

// ── Edita estos datos con tu información ──────────────────────────────────────
const nombre    = "Álvaro González Luque";
const rol       = "Ingeniero Informático";
const contacto  = "alvaro.g.luq@gmail.com";
const github    = "https://github.com/abbonno";
const linkedin  = "www.linkedin.com/in/agl-abbonno";

const proyectos = [
  {
    title: "MiniWare",
    description: "Framework de creación de minijuegos al estilo WarioWare",
    href: "https://github.com/abbonno/mini-ware",
    tags: ["Godot", "Gamificación", "WarioWare"],
    year: "2025",
    status: "archived" as const,
  },
  {
    title: "Tinta y sangre",
    description: "Página de soporte para visualización de un libro digital.",
    href: "https://github.com/abbonno/TintaSangreCia",
    tags: ["Astro", "JavaScript", "CSS"],
    year: "2024",
    status: "uncontinued" as const,
  },
  {
    title: "miTiendaOnline",
    description: "Proyecto de práctica de desarrollo web con React.",
    href: "https://github.com/abbonno/miTiendaOnline",
    tags: ["React", "JavaScript", "Tailwind CSS"],
    year: "2023",
    status: "wip" as const,
  },
];
// ─────────────────────────────────────────────────────────────────────────────
---

<Layout title={`${nombre} — Portfolio`}>

  <!-- FONDO DECORATIVO -->
  <div class="bg-grid" aria-hidden="true"></div>
  <div class="bg-glow" aria-hidden="true"></div>

  <div class="wrapper">

    <!-- NAV -->
    <nav class="nav">
      <span class="nav-logo">{nombre.split(" ")[0]}<span class="accent">.</span></span>
      <div class="nav-links">
        <a href="#proyectos">Proyectos</a>
        <p class="nav-cta">{contacto}</p>
      </div>
    </nav>

    <!-- HERO -->
    <header class="hero">
      <h1 class="hero-title">
        {nombre}<br />
        <span class="hero-role">{rol}</span>
      </h1>


      <div class="hero-actions">
        <a href={github} target="_blank" rel="noopener" class="btn btn-ghost">GitHub</a>
        <a href={linkedin} target="_blank" rel="noopener" class="btn btn-ghost">LinkedIn</a>
      </div>
    </header>

    <!-- PROYECTOS -->
    <section id="proyectos" class="projects-section">
      <div class="section-header">
        <h2 class="section-title">Proyectos</h2>
        <span class="section-count">{proyectos.length} proyectos</span>
      </div>

      <ul class="card-grid">
        {proyectos.map((p) => (
          <Card
            title={p.title}
            description={p.description}
            href={p.href}
            tags={p.tags}
            year={p.year}
            status={p.status}
          />
        ))}
      </ul>
    </section>

    <!-- FOOTER -->
    <footer class="footer">
      <p class="footer-text">
        Construido con <a href="https://astro.build" target="_blank" rel="noopener">Astro</a> · {new Date().getFullYear()}
      </p>
      <div class="footer-links">
        <a href={github} target="_blank" rel="noopener">GitHub</a>
        <a href={linkedin} target="_blank" rel="noopener">LinkedIn</a>
        <p>{contacto}</p>
      </div>
    </footer>

  </div>
</Layout>

<style>
  /* ── Layout ─────────────────────────────────────────────── */
  .wrapper {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 1.5rem;
    position: relative;
    z-index: 1;
  }

  /* ── Fondo ──────────────────────────────────────────────── */
  .bg-grid {
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 48px 48px;
    pointer-events: none;
    z-index: 0;
  }

  .bg-glow {
    position: fixed;
    top: -20vh;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(232, 255, 90, 0.06) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  /* ── Nav ────────────────────────────────────────────────── */
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 2rem 0 3rem;
  }

  .nav-logo {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.25rem;
    letter-spacing: -0.02em;
    color: var(--text);
  }

  .accent { color: var(--accent); }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-links a {
    font-size: 0.875rem;
    color: var(--muted);
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--text); }

  .nav-cta {
    font-size: 0.875rem !important;
    color: var(--accent) !important;
    border: 1px solid rgba(232, 255, 90, 0.3);
    padding: 0.4em 1em;
    border-radius: 6px;
    transition: background 0.2s, color 0.2s !important;
  }

  .nav-cta:hover {
    background: var(--accent-dim) !important;
  }

  /* ── Hero ───────────────────────────────────────────────── */
  .hero {
    padding: 4rem 0 6rem;
    animation: fadeUp 0.7s ease both;
  }

  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--muted);
    letter-spacing: 0.05em;
    margin-bottom: 2rem;
    text-transform: uppercase;
  }

  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #4ade80;
    box-shadow: 0 0 8px #4ade80;
    animation: pulse 2.5s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.3; }
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 8vw, 5.5rem);
    font-weight: 800;
    line-height: 1.02;
    letter-spacing: -0.03em;
    color: var(--text);
    margin-bottom: 1.5rem;
  }

  .hero-role {
    color: var(--accent);
    font-weight: 600;
    font-size: 0.65em;
    letter-spacing: -0.01em;
  }
  
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  /* ── Botones ────────────────────────────────────────────── */
  .btn {
    display: inline-block;
    font-size: 0.875rem;
    font-family: var(--font-body);
    font-weight: 500;
    border-radius: 8px;
    padding: 0.65em 1.4em;
    transition: all 0.2s ease;
    cursor: pointer;
    border: none;
  }

  .btn-primary {
    background: var(--accent);
    color: #000;
    font-weight: 600;
  }

  .btn-primary:hover {
    background: #f0ff80;
    transform: translateY(-1px);
    box-shadow: 0 4px 20px rgba(232, 255, 90, 0.3);
  }

  .btn-ghost {
    background: transparent;
    color: var(--muted);
    border: 1px solid var(--border);
  }

  .btn-ghost:hover {
    border-color: rgba(255,255,255,0.18);
    color: var(--text);
    background: rgba(255,255,255,0.04);
  }

  /* ── Proyectos ──────────────────────────────────────────── */
  .projects-section {
    padding: 2rem 0 6rem;
    animation: fadeUp 0.7s 0.15s ease both;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text);
  }

  .section-count {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--muted);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
    padding: 0;
  }

  /* ── Footer ─────────────────────────────────────────────── */
  .footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    padding: 2rem 0 3rem;
    border-top: 1px solid var(--border);
  }

  .footer-text {
    font-size: 0.8rem;
    color: var(--muted);
  }

  .footer-text a {
    color: var(--accent);
    transition: opacity 0.2s;
  }

  .footer-text a:hover { opacity: 0.7; }

  .footer-links {
    display: flex;
    gap: 1.25rem;
  }

  .footer-links a {
    font-size: 0.8rem;
    color: var(--muted);
    transition: color 0.2s;
  }

  .footer-links a:hover { color: var(--text); }

  /* ── Animación ──────────────────────────────────────────── */
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ── Responsive ─────────────────────────────────────────── */
  @media (max-width: 600px) {
    .nav { padding: 1.5rem 0 2rem; }
    .hero { padding: 2rem 0 4rem; }
    .footer { flex-direction: column; align-items: flex-start; }
    .card-grid { grid-template-columns: 1fr; }
  }
</style>